APP_NAME=ComercioPlus
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE_SHOW
APP_DEBUG=false
APP_URL=https://comercioplusoficial-production.up.railway.app
ASSET_URL=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_RAILWAY_MYSQL_HOST
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_RAILWAY_MYSQL_PASSWORD
DATABASE_URL=

# Railway aliases soportados por config/database.php
MYSQLHOST=REPLACE_WITH_RAILWAY_MYSQL_HOST
MYSQLPORT=3306
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=REPLACE_WITH_RAILWAY_MYSQL_PASSWORD
MYSQL_URL=mysql://root:REPLACE_WITH_RAILWAY_MYSQL_PASSWORD@REPLACE_WITH_RAILWAY_MYSQL_HOST:3306/railway
MYSQL_PUBLIC_URL=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.comercio-plus-oficial.vercel.app
SESSION_ENCRYPT=false
SESSION_PATH=/

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@comercioplus.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://comercio-plus-oficial.vercel.app
VERCEL_PROD_ORIGIN=https://comercio-plus-oficial.vercel.app
SANCTUM_STATEFUL_DOMAINS=comercio-plus-oficial.vercel.app
CORS_ALLOWED_ORIGINS=https://comercio-plus-oficial.vercel.app
CORS_ALLOWED_ORIGIN_PATTERNS=

WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_API_URL=https://production.wompi.co/v1

CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_CLOUDINARY_API_SECRET
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_URL=
