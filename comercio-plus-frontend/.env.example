# URL base del backend.
# Produccion recomendada (Vercel + rewrites): /api
# Ejemplo produccion: https://comercioplusoficial-production.up.railway.app/api
VITE_API_BASE_URL=
# Alias opcional soportado por runtime.ts
VITE_API_URL=
# Railway (ejemplo):
# VITE_API_BASE_URL=https://tu-app.up.railway.app/api
# Solo para desarrollo local cuando VITE_API_BASE_URL esta vacio.
# Vite proxea /api y /sanctum a este host.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_APP_NAME=ComercioPlus
VITE_APP_VERSION=1.0.0

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_SOCIAL_LOGIN=false
# Si defines light|dark, bloquea el tema para todos los usuarios en ese entorno.
VITE_FORCE_THEME=
# Variantes de iconos: emoji (API + fallback) | fa (lucide)
VITE_ICON_VARIANT=emoji
VITE_EMOJI_API_BASE=https://api.iconify.design
VITE_EMOJI_ICON_SET=fluent-emoji

# Claude / Anthropic (placeholders, sin secretos reales)
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
CLAUDE_API_KEY=REPLACE_WITH_CLAUDE_API_KEY
CLAUDE_MODEL=claude-3-5-sonnet-latest
